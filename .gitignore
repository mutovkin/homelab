# Ignore everything under .claude/ except shared, version-controlled config
.claude/*
!.claude/settings.json
!.claude/skills
.claude/skills/*
!.claude/skills/homelab-change-loop

# Ansible
.vault_password
*.retry
ansible/.ansible/

# Rendered service secrets — templated onto hosts at deploy time, never committed
*.env
.env
# …but keep the committed example/template files
!*.env.example
!*.env.template

# OS
.DS_Store
