# SearXNG Environment Variables
# Copy this file to .env and fill in your actual values

# SearXNG Configuration
SEARXNG_HOSTNAME=search.example.com
SEARXNG_SECRET=your-random-secret-key-here-use-openssl-rand-hex-32

# Docker network subnet (overrides the compose default; set via host_vars docker_networks)
SEARXNG_NETWORK_SUBNET=172.22.0.0/24
