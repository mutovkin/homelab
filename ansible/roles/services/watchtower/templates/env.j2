# Watchtower — templated by Ansible from vault variables
WATCHTOWER_SCHEDULE={{ watchtower_schedule }}
WATCHTOWER_TIMEZONE={{ watchtower_timezone }}
EMAIL_FROM={{ vault_watchtower_email_from }}
EMAIL_TO={{ vault_watchtower_email_to }}
EMAIL_SERVER={{ vault_watchtower_email_server }}
EMAIL_PORT={{ vault_watchtower_email_port }}
EMAIL_USER={{ vault_watchtower_email_user }}
EMAIL_PASSWORD={{ vault_watchtower_email_password }}

# Docker network subnet (single source of truth: host_vars docker_networks)
WATCHTOWER_NETWORK_SUBNET={{ docker_networks.watchtower | default('172.25.0.0/24') }}
