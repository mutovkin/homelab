# NextCloud — templated by Ansible from vault variables
NEXTCLOUD_DB_DATABASE={{ vault_nextcloud_db_database | default('nextcloud') }}
NEXTCLOUD_DB_USERNAME={{ vault_nextcloud_db_username | default('nextcloud') }}
NEXTCLOUD_DB_PASSWORD={{ vault_nextcloud_db_password }}
NEXTCLOUD_ADMIN_USER={{ vault_nextcloud_admin_user }}
NEXTCLOUD_ADMIN_PASSWORD={{ vault_nextcloud_admin_password }}
NEXTCLOUD_TRUSTED_DOMAINS={{ vault_nextcloud_trusted_domains | default('localhost') }}
SMTP_USERNAME={{ vault_nextcloud_smtp_username }}
SMTP_PASSWORD={{ vault_nextcloud_smtp_password }}
SMTP_FROM_ADDRESS={{ vault_nextcloud_smtp_from | default('nextcloud') }}
TIMEZONE={{ timezone }}
NEXTCLOUD_DATA_DIR={{ data_mount }}/nextcloud/data
NEXTCLOUD_NETWORK_SUBNET={{ docker_networks.nextcloud | default('172.33.0.0/24') }}
