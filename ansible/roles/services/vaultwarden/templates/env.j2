# Vaultwarden — templated by Ansible from vault variables
DOMAIN={{ vault_vaultwarden_domain }}
ADMIN_TOKEN={{ vault_vaultwarden_admin_token }}
SIGNUPS_DOMAINS_WHITELIST={{ vault_vaultwarden_signups_domains }}
SMTP_HOST={{ vault_smtp_host }}
SMTP_FROM={{ vault_smtp_from }}
SMTP_FROM_NAME={{ vault_smtp_from_name | default('Vaultwarden') }}
SMTP_SECURITY={{ vault_smtp_security | default('starttls') }}
SMTP_PORT={{ vault_smtp_port | default('587') }}
SMTP_USERNAME={{ vault_smtp_username }}
SMTP_PASSWORD={{ vault_smtp_password }}
SMTP_AUTH_MECHANISM={{ vault_smtp_auth_mechanism | default('Plain') }}
