# Observability Stack — templated by Ansible from vault variables
TIMEZONE={{ timezone }}
DOCKER_GID={{ docker_gid | default('999') }}
GRAFANA_USER={{ vault_grafana_user }}
GRAFANA_PASSWORD={{ vault_grafana_password }}
GRAFANA_ROOT_URL={{ vault_grafana_root_url }}
GRAFANA_DOMAIN={{ vault_grafana_domain }}
VM_AUTH_USERNAME={{ vault_vm_auth_username | default('') }}
VM_AUTH_PASSWORD={{ vault_vm_auth_password | default('') }}
VL_AUTH_USERNAME={{ vault_vl_auth_username | default('') }}
VL_AUTH_PASSWORD={{ vault_vl_auth_password | default('') }}
VM_MEMORY_LIMIT={{ vm_memory_limit | default('2G') }}
VL_MEMORY_LIMIT={{ vl_memory_limit | default('1G') }}
VECTOR_MEMORY_LIMIT={{ vector_memory_limit | default('512M') }}
TELEGRAF_MEMORY_LIMIT={{ telegraf_memory_limit | default('256M') }}
GRAFANA_MEMORY_LIMIT={{ grafana_memory_limit | default('1G') }}
ROUTER_IP={{ router_ip | default('192.168.1.1') }}
SNMP_COMMUNITY={{ snmp_community | default('public') }}
